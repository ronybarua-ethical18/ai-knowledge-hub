# Public URL of the Next.js app (used in email links; no trailing slash)
FRONTEND_URL=http://localhost:3000

# JWT Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
JWT_SECRET=your-super-secret-jwt-key-here-make-it-long-and-random
JWT_REFRESH_SECRET=your-super-secret-refresh-key-here

# OAuth Configuration (for future use)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Email Configuration (for future use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

GLOBAL_PREFIX=api/v1
PORT=8000

# Qdrant — local: http://localhost:6333 (leave QDRANT_API_KEY empty)
# Qdrant Cloud: cluster URL with port, e.g. https://xxxx.sa-east-1-0.aws.cloud.qdrant.io:6333
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Google AI (AI Studio API key) — embeddings default to gemini-embedding-001
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# Free tier: prefer Flash-Lite; alternates gemini-2.5-flash / gemini-2.0-flash / gemini-1.5-flash (gemini-pro is deprecated)
GEMINI_CHAT_MODEL=gemini-2.5-flash-lite